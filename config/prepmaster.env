# Editable project settings for Raspberry Pi deployment.

PREPMASTER_ROOT=/opt/prepmaster
PREPMASTER_SRC_DIR=/opt/prepmaster/src
PREPMASTER_WEB_ROOT=/srv/prepmaster/www
PREPMASTER_DATA_ROOT=/srv/prepmaster/data
PREPMASTER_ADMIN_ROOT=/srv/prepmaster/www/admin
PREPMASTER_MAPS_ROOT=/srv/prepmaster/www/maps

KIWIX_LIBRARY_DIR=/library/zims/content
KIWIX_LIBRARY_XML=/srv/prepmaster/data/kiwix/library.xml
KIWIX_PORT=8080
KIWIX_BIND_ADDRESS=auto
PREPMASTER_ZIM_PROFILE=essential
PREPMASTER_WIKIPEDIA_OPTION=top-mini
PREPMASTER_ZIM_MODE=full
MAPS_PORT=8079
ADMIN_PORT=8081
PREPMASTER_ALLOW_LEGACY_KA_LITE=0
PREPMASTER_AP_ENABLED=0
PREPMASTER_AP_INTERFACE=wlan0
PREPMASTER_AP_SSID=PrepmasterHub
PREPMASTER_AP_PASSPHRASE=PrepmasterLocal
PREPMASTER_AP_COUNTRY=US
PREPMASTER_AP_CHANNEL=6
PREPMASTER_AP_ADDRESS=192.168.50.1
PREPMASTER_AP_NETMASK=255.255.255.0
PREPMASTER_AP_CIDR=24
PREPMASTER_AP_DHCP_START=192.168.50.20
PREPMASTER_AP_DHCP_END=192.168.50.120
PREPMASTER_AP_DHCP_LEASE=24h

PREPMASTER_HOSTNAME=prepmaster
