MAPS_PORT=8079
ADMIN_PORT=8081
SOPR_ALLOW_LEGACY_KA_LITE=0
SOPR_AP_ENABLED=0
SOPR_AP_INTERFACE=wlan0
SOPR_AP_SSID=SOPR
SOPR_AP_PASSPHRASE=Joshua123
SOPR_AP_COUNTRY=US
SOPR_AP_CHANNEL=6
SOPR_AP_ADDRESS=192.168.50.1
SOPR_AP_NETMASK=255.255.255.0
SOPR_AP_CIDR=24
