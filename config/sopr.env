SOPR_AP_DHCP_END=192.168.50.120
SOPR_AP_DHCP_LEASE=24h

SOPR_HOSTNAME=sopr
SOPR_WIKIPEDIA_OPTION=simple-all-mini
SOPR_AP_ENABLED=0
SOPR_AP_SSID=SOPR
SOPR_AP_PASSPHRASE=Joshua123
