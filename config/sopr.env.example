# Copy to config/sopr.env and adjust as needed.

SOPR_ROOT=/opt/sopr
SOPR_SRC_DIR=/opt/sopr/src
SOPR_WEB_ROOT=/srv/sopr/www
SOPR_DATA_ROOT=/srv/sopr/data
SOPR_ADMIN_ROOT=/srv/sopr/www/admin
SOPR_MAPS_ROOT=/srv/sopr/www/maps

SOPR_INSTALL_KIWIX=1
SOPR_INSTALL_KOLIBRI=0
SOPR_INSTALL_KA_LITE=0
SOPR_INSTALL_MAPS=1
SOPR_AP_ENABLED=0
SOPR_AP_INTERFACE=wlan0
SOPR_AP_ADDRESS=192.168.50.1
SOPR_AP_NETMASK=255.255.255.0
SOPR_AP_CIDR=24
SOPR_AP_DHCP_START=192.168.50.50
SOPR_AP_DHCP_END=192.168.50.150
SOPR_AP_LEASE=12h
SOPR_AP_CHANNEL=6
SOPR_AP_COUNTRY=US

KIWIX_PORT=8080
KIWIX_LIBRARY_DIR=/library/zims/content
KIWIX_LIBRARY_XML=/srv/sopr/data/kiwix/library.xml
KIWIX_AUTO_LIBRARY_XML=1
KIWIX_HOST=0.0.0.0

SOPR_ZIM_PROFILE=essential
SOPR_ZIM_MODE=full
SOPR_WIKIPEDIA_OPTION=top-mini
SOPR_MAP_COLLECTIONS=
SOPR_MAP_PMTILES_FILE=
SOPR_MAP_CATALOG_URL=https://raw.githubusercontent.com/Crosstalk-Solutions/project-nomad/refs/heads/main/collections/maps.json
SOPR_ZIM_CATALOG_URL=https://download.kiwix.org/zim/
SOPR_ZIM_CUSTOM_URL_FILE=/opt/sopr/src/config/kiwix-zim-urls.custom.txt
SOPR_ZIM_CUSTOM_SELECTION_FILE=/opt/sopr/src/config/kiwix-zim-selection.json
SOPR_HOST_IP=192.168.50.1
SOPR_HOST_FALLBACK_IP=127.0.0.1
SOPR_HOST_FALLBACK_NAME=localhost
SOPR_HOST_IP_LIST=
SOPR_HOSTNAME=sopr
SOPR_AP_SSID=SOPRHub
SOPR_AP_PASSPHRASE=SoprLocal
SOPR_HTTP_PORT=80
SOPR_CONTENT_TAG_CSV=
SOPR_ALLOW_LEGACY_KA_LITE=0
