# Copy to config/sopr.env and adjust as needed.

PREPMASTER_ROOT=/opt/sopr
PREPMASTER_SRC_DIR=/opt/sopr/src
PREPMASTER_WEB_ROOT=/srv/sopr/www
PREPMASTER_DATA_ROOT=/srv/sopr/data
PREPMASTER_ADMIN_ROOT=/srv/sopr/www/admin
PREPMASTER_MAPS_ROOT=/srv/sopr/www/maps
PREPMASTER_MAP_PMTILES_ROOT=/maps
PREPMASTER_MAP_PMTILES_FILE=basemap.pmtiles
PREPMASTER_MAP_STYLE_FLAVOR=dark
PREPMASTER_MAP_LANGUAGE=en
PREPMASTER_MAP_REPO_OWNER=Crosstalk-Solutions
PREPMASTER_MAP_REPO_NAME=project-nomad-maps
PREPMASTER_MAP_REPO_BRANCH=master
PREPMASTER_MAP_REPO_SUBDIR=pmtiles
PREPMASTER_MAP_COLLECTIONS_URL=https://raw.githubusercontent.com/Crosstalk-Solutions/project-nomad/refs/heads/main/collections/maps.json
PREPMASTER_MAP_SELECTED_COLLECTIONS=
PREPMASTER_MAP_SELECTED_FILES=
PREPMASTER_MAP_INSTALL_DIR=
PREPMASTER_MAP_DEFAULT_LAT=39.8283
PREPMASTER_MAP_DEFAULT_LON=-98.5795
PREPMASTER_MAP_DEFAULT_ZOOM=4
PREPMASTER_MAP_MIN_ZOOM=2
PREPMASTER_MAP_MAX_ZOOM=14

KIWIX_LIBRARY_DIR=/library/zims/content
KIWIX_LIBRARY_XML=/srv/sopr/data/kiwix/library.xml
KIWIX_PORT=8080
PREPMASTER_KOLIBRI_PORT=8082
KIWIX_BIND_ADDRESS=auto
PREPMASTER_ZIM_INSTALL_DIR=
PREPMASTER_ZIM_PROFILE=essential
PREPMASTER_WIKIPEDIA_OPTION=top-mini
PREPMASTER_ZIM_MODE=full
PREPMASTER_ZIM_CUSTOM_BASE_PROFILE=essential
PREPMASTER_ZIM_CATALOG_URL=https://download.kiwix.org/zim/
PREPMASTER_ZIM_CUSTOM_URL_FILE=/opt/sopr/src/config/kiwix-zim-urls.custom.txt
PREPMASTER_ZIM_CUSTOM_SELECTION_FILE=/opt/sopr/src/config/kiwix-zim-selection.json
MAPS_PORT=8079
ADMIN_PORT=8081
PREPMASTER_ALLOW_LEGACY_KA_LITE=0
PREPMASTER_AP_ENABLED=0
PREPMASTER_AP_INTERFACE=wlan0
PREPMASTER_AP_SSID=SOPRHub
PREPMASTER_AP_PASSPHRASE=SoprLocal
PREPMASTER_AP_COUNTRY=US
PREPMASTER_AP_CHANNEL=6
PREPMASTER_AP_ADDRESS=192.168.50.1
PREPMASTER_AP_NETMASK=255.255.255.0
PREPMASTER_AP_CIDR=24
PREPMASTER_AP_DHCP_START=192.168.50.20
PREPMASTER_AP_DHCP_END=192.168.50.120
PREPMASTER_AP_DHCP_LEASE=24h

PREPMASTER_HOSTNAME=sopr
